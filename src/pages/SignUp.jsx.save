import React, { useState } from 'react';
import { useNavigate } from 'react-router-dom';
import { auth } from '../firebase';
import Swal from 'sweetalert2';
import { createUserWithEmailAndPassword } from 'firebase/auth';
import emailjs from '@emailjs/browser';
import './index.css';

export default function SignUp() {
  const navigate = useNavigate();
  const [firstName, setFirstName] = useState('');
  const [surname, setSurname] = useState('');
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [showPassword, setShowPassword] = useState(false);

  const handleSignUp = async (e) => {
    e.preventDefault();
    const fullName = `${firstName} ${surname}`;

    // 1. Sleek "Creating" Loader
    Swal.fire({
      title: 'Processing...',
      text: 'Building your Bossnet profile',
      background: 'rgba(26, 26, 32, 0.8)',
      color: '#fff',
      backdrop: `rgba(0,0,0,0.6) blur(10px)`,
      showConfirmButton: false,
      allowOutsideClick: false,
      didOpen: () => { Swal.showLoading(); }
    });

    try {
      const newCode = Math.floor(100000 + Math.random() * 900000);

      await emailjs.send(
        'service_r3hyhto',
        'template_5z31kwn',
        { to_name: fullName, to_email: email, verification_code: newCode },
        'FOxONsRPS4W7EA5zK'
      );

      await createUserWithEmailAndPassword(auth, email, password);

      // 2. Custom SUCCESS (Like your "Completed" photo)
      Swal.fire({
        title: 'COMPLETED',
        text: `Welcome to the network, ${firstName}! Verification code sent.`,
        icon: 'success',
        iconColor: '#4ade80',
        background: 'rgba(255, 255, 255, 0.1)', // Glass effect
        color: '#fff',
        backdrop: `rgba(0,0,0,0.7) blur(15px)`,
        confirmButtonText: 'Continue',
        confirmButtonColor: '#4ade80',
        customClass: {
          popup: 'glass-popup',
          confirmButton: 'rounded-full px-10 py-3 font-bold'
        }
      }).then(() => {
        navigate('/verify', { state: { generatedCode: newCode, email, fullName } });
      });

    } catch (error) {
      // 3. Custom ERROR (Like your "Error" photo)
      Swal.fire({
        title: 'ERROR',
        text: error.message || "Something went wrong. Try again.",
        icon: 'error',
        iconColor: '#f43f5e',
        background: 'rgba(255, 255, 255, 0.1)', // Glass effect
        color: '#fff',
        backdrop: `rgba(0,0,0,0.7) blur(15px)`,
        confirmButtonText: 'Try again',
        confirmButtonColor: '#f43f5e',
        customClass: {
          popup: 'glass-popup',
          confirmButton: 'rounded-full px-10 py-3 font-bold'
        }
      });
    }
  };

  return (
    <div className="min-h-screen w-full flex flex-col items-center justify-center py-12 px-4 bg-[#020205] relative overflow-hidden">
      
      {/* 1. REAL NEBULA LOGIC: Layered radial glows for depth */}
      <div className="absolute inset-0 z-0 pointer-events-none">
        {/* Technical Grid */}
        <div 
          className="absolute inset-0 opacity-10" 
          style={{ 
            backgroundImage: `linear-gradient(#4f4f5e 1px, transparent 1px), linear-gradient(90deg, #4f4f5e 1px, transparent 1px)`, 
            backgroundSize: '50px 50px' 
          }}
        ></div>
        
        {/* Nebula Hues: Purple, Blue, and Orange accents */}
        <div className="absolute top-[5%] left-[-5%] w-[80%] h-[70%] bg-[radial-gradient(circle,rgba(142,68,173,0.18)_0%,transparent_70%)] blur-[100px]"></div>
        <div className="absolute bottom-[0%] right-[-5%] w-[75%] h-[60%] bg-[radial-gradient(circle,rgba(24,119,242,0.18)_0%,transparent_70%)] blur-[100px]"></div>
        <div className="absolute top-[35%] left-[25%] w-[45%] h-[45%] bg-[radial-gradient(circle,rgba(255,165,0,0.07)_0%,transparent_60%)] blur-[120px]"></div>
      </div>

      {/* 2. JOIN BOSSNET HEADER: Gradient Text */}
      <h1 className="relative z-10 text-5xl md:text-6xl font-black mb-10 tracking-tight bg-gradient-to-r from-[#f39c12] via-[#e67e22] to-[#9b59b6] bg-clip-text text-transparent drop-shadow-[0_10px_10px_rgba(0,0,0,0.5)]">
        Join Bossnet
      </h1>

      {/* 3. MAIN FORM CONTAINER: Rounded edges [40px] */}
      <div className="relative z-10 bg-[#0f0f13]/85 backdrop-blur-3xl p-8 rounded-[40px] border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.8)] max-w-[420px] w-full">
        
        {/* Navigation Button: Functions Untampered */}
        <button 
          onClick={() => navigate('/')} 
          className="w-full h-12 mb-8 flex items-center justify-center gap-2 rounded-full bg-gradient-to-r from-[#8e44ad] to-[#1877f2] text-white font-bold shadow-lg active:scale-95 transition-all"
        >
          <span className="text-xl">←</span> Back to Login
        </button>

        <h2 className="text-xl font-semibold text-center mb-8 text-blue-400/80 tracking-wide uppercase">
          Create Account
        </h2>

        {/* Form Function: Functions Untampered */}
        <form onSubmit={handleSignUp} className="space-y-5">
          <div className="flex gap-3">
<input 
  type="text" 
  value={firstName} 
  onChange={(e) => setFirstName(e.target.value)} 
  placeholder="First name" 
  required 
  className="w-1/2 py-4 px-6 bg-[#1a1a20]/90 border border-white/10 rounded-full text-white placeholder-white/70 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition-all" 
/>
<input 
  type="text" 
  value={surname} 
  onChange={(e) => setSurname(e.target.value)} 
  placeholder="Surname" 
  required 
  className="w-1/2 py-4 px-6 bg-[#1a1a20]/90 border border-white/10 rounded-full text-white placeholder-white/70 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition-all" 
/>
          </div>
          
<input 
  type="text" 
  value={email} 
  onChange={(e) => setEmail(e.target.value)} 
  placeholder="Mobile number or email address" 
  required 
  className="w-full py-4 px-6 bg-[#1a1a20]/90 border border-white/10 rounded-full text-white placeholder-white/70 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition-all" 
/>
          
<div className="relative">
  <input 
    type={showPassword ? "text" : "password"} 
    value={password} 
    onChange={(e) => setPassword(e.target.value)} 
    placeholder="New password" 
    required 
    className="w-full py-4 px-6 bg-[#1a1a20]/90 border border-white/10 rounded-full text-white placeholder-white/70 focus:border-purple-500 focus:ring-1 focus:ring-purple-500 outline-none transition-all" 
  />
  <button
    type="button"
    onClick={() => setShowPassword(!showPassword)}
    className="absolute right-6 top-1/2 -translate-y-1/2 text-white/70 font-bold text-sm hover:text-white transition-colors"
  >
    {showPassword ? "Hide" : "Show"}
  </button>
</div>

          <button
            type="submit"
            className="w-full h-14 mt-6 rounded-full bg-gradient-to-r from-[#8e44ad] to-[#1877f2] text-white font-bold shadow-lg active:scale-95 transition-all"
          >
            Sign Up
          </button>
        </form>
      </div>
    </div>
  );
}

